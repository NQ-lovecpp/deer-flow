# Spark ComfyUI compose defaults.
# Copy to .env for local overrides:
#   cp deploy/spark/comfy/.env.example deploy/spark/comfy/.env

# Service identity
COMFYUI_CONTAINER_NAME=deer-flow-comfyui
COMFYUI_IMAGE=deer-flow-spark-comfy:0c63b4f6
COMFYUI_PORT=8188

# To test side-by-side with the existing host daemon on 8188, set:
# COMFYUI_PORT=8189
# and run DeerFlow smoke tests with COMFYUI_URL=http://127.0.0.1:8189.

# Build inputs. Defaults are chosen for Spark/aarch64 + CUDA 13 and China networks.
COMFYUI_BASE_IMAGE=nvcr.io/nvidia/pytorch:25.11-py3
COMFYUI_GIT_REF=0c63b4f6e3ce807a0f85c1826710bcf18ade3e2c
COMFYUI_REPO_URL=https://gitcode.com/gh_mirrors/co/ComfyUI.git

# China mirrors. Switch COMFYUI_REPO_URL back to GitHub only if the GitCode
# mirror lags or misses a target commit.
APT_MIRROR=https://mirrors.tuna.tsinghua.edu.cn/ubuntu-ports
PIP_INDEX_URL=https://pypi.tuna.tsinghua.edu.cn/simple
PIP_EXTRA_INDEX_URL=
PIP_TRUSTED_HOST=pypi.tuna.tsinghua.edu.cn

# Host paths. These directories are not copied into the image.
COMFYUI_ROOT=/home/chen/comfyui/ComfyUI
COMFYUI_MODELS_DIR=/home/chen/comfyui/ComfyUI/models
COMFYUI_INPUT_DIR=/home/chen/comfyui/ComfyUI/input
COMFYUI_OUTPUT_DIR=/home/chen/comfyui/ComfyUI/output
COMFYUI_USER_DIR=/home/chen/comfyui/ComfyUI/user
COMFYUI_CUSTOM_NODES_DIR=/home/chen/comfyui/ComfyUI/custom_nodes

# Keep container writes owned by the Spark user.
COMFYUI_UID=1000
COMFYUI_GID=1000

# GPU/container runtime knobs.
COMFYUI_GPUS=all
COMFYUI_SHM_SIZE=16gb
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# Extra ComfyUI main.py flags. Examples:
# COMFYUI_EXTRA_ARGS=--lowvram
# COMFYUI_EXTRA_ARGS=--disable-xformers
COMFYUI_EXTRA_ARGS=

# DeerFlow should keep using this stable interface after the service starts.
COMFYUI_URL=http://127.0.0.1:8188
